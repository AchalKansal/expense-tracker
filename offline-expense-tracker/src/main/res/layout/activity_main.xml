<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════ MAIN CONTENT ═══════════════════ -->
    <LinearLayout
        android:id="@+id/mainRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/background"
        android:orientation="vertical">

        <ScrollView
            android:id="@+id/rootScroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@color/background"
            android:fillViewport="true">

            <LinearLayout
                android:id="@+id/rootContent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <!-- Header -->
                <LinearLayout
                    android:id="@+id/headerPanel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/menuButton"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/type_toggle_background"
                        android:text="☰"
                        android:textSize="18sp"
                        android:includeFontPadding="false"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true"
                        android:padding="0dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/titleText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/app_name"
                            android:textColor="@color/ink"
                            android:textSize="25sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/subtitleText"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Private money diary. No login. No internet."
                            android:textColor="@color/muted"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <Switch
                        android:id="@+id/themeSwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="48dp"
                        android:text="Dark"
                        android:textColor="@color/ink"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Tabs -->
                <RadioGroup
                    android:id="@+id/mainTabGroup"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/entryTabRadio"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/type_toggle_background"
                        android:button="@null"
                        android:checked="true"
                        android:gravity="center"
                        android:text="Tracker"
                        android:textColor="@color/ink"
                        android:textStyle="bold" />

                    <RadioButton
                        android:id="@+id/chartTabRadio"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/type_toggle_background"
                        android:button="@null"
                        android:gravity="center"
                        android:text="Overview"
                        android:textColor="@color/ink"
                        android:textStyle="bold" />
                </RadioGroup>

                <!-- Summary Card -->
                <LinearLayout
                    android:id="@+id/summaryCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:id="@+id/todaySummaryCell"
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_background"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/todayLabelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Today spent"
                                android:textColor="@color/muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/todaySpentText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:textColor="@color/expense"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/monthSummaryCell"
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginStart="6dp"
                            android:layout_marginEnd="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_background"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/monthLabelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Month spent"
                                android:textColor="@color/muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/monthSpentText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:textColor="@color/expense"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:id="@+id/balanceSummaryCell"
                            android:layout_width="0dp"
                            android:layout_height="82dp"
                            android:layout_marginStart="6dp"
                            android:layout_weight="1"
                            android:background="@drawable/input_background"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="6dp">

                            <TextView
                                android:id="@+id/balanceLabelText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Balance"
                                android:textColor="@color/muted"
                                android:textSize="11sp" />

                            <TextView
                                android:id="@+id/budgetStatusText"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="5dp"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Entry Section -->
                <LinearLayout
                    android:id="@+id/entrySection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <!-- Expense / Income toggle -->
                    <RadioGroup
                        android:id="@+id/typeGroup"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/expenseRadio"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/type_toggle_background"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:text="Expense"
                            android:textColor="@color/ink"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/incomeRadio"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/type_toggle_background"
                            android:button="@null"
                            android:gravity="center"
                            android:text="Income"
                            android:textColor="@color/ink"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <!-- Amount + Date icon on one row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <EditText
                            android:id="@+id/amountInput"
                            android:layout_width="0dp"
                            android:layout_height="50dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:background="@drawable/input_background"
                            android:hint="Amount"
                            android:inputType="numberDecimal"
                            android:maxLines="1"
                            android:textColor="@color/ink"
                            android:textColorHint="@color/muted" />

                        <TextView
                            android:id="@+id/dateButton"
                            android:layout_width="wrap_content"
                            android:layout_height="50dp"
                            android:background="@drawable/type_toggle_background"
                            android:text=""
                            android:textSize="12sp"
                            android:singleLine="true"
                            android:gravity="center"
                            android:clickable="true"
                            android:focusable="true"
                            android:paddingStart="14dp"
                            android:paddingEnd="14dp" />
                    </LinearLayout>

                    <!-- Category chips (wrapping flow) -->
                    <com.offline.expense.FlowLayout
                        android:id="@+id/categoryChipContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp" />

                    <EditText
                        android:id="@+id/noteInput"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/input_background"
                        android:hint="Note optional"
                        android:inputType="textCapSentences"
                        android:maxLines="1"
                        android:textColor="@color/ink"
                        android:textColorHint="@color/muted" />

                    <Button
                        android:id="@+id/addButton"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginTop="12dp"
                        android:background="@drawable/primary_button"
                        android:text="Add Expense"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Chart Section -->
                <LinearLayout
                    android:id="@+id/chartSection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:background="@drawable/card_background"
                    android:orientation="vertical"
                    android:padding="14dp"
                    android:visibility="gone">

                    <TextView
                        android:id="@+id/chartTitleText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Expense chart"
                        android:textColor="@color/ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <RadioGroup
                        android:id="@+id/chartPeriodGroup"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/monthlyChartRadio"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/type_toggle_background"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:text="Monthly"
                            android:textColor="@color/ink"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/yearlyChartRadio"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/type_toggle_background"
                            android:button="@null"
                            android:gravity="center"
                            android:text="Yearly"
                            android:textColor="@color/ink"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <RadioGroup
                        android:id="@+id/chartStyleGroup"
                        android:layout_width="match_parent"
                        android:layout_height="44dp"
                        android:layout_marginTop="10dp"
                        android:orientation="horizontal">

                        <RadioButton
                            android:id="@+id/barChartRadio"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="8dp"
                            android:layout_weight="1"
                            android:background="@drawable/type_toggle_background"
                            android:button="@null"
                            android:checked="true"
                            android:gravity="center"
                            android:text="Donut"
                            android:textColor="@color/ink"
                            android:textStyle="bold" />

                        <RadioButton
                            android:id="@+id/pieChartRadio"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:background="@drawable/type_toggle_background"
                            android:button="@null"
                            android:gravity="center"
                            android:text="Trend"
                            android:textColor="@color/ink"
                            android:textStyle="bold" />
                    </RadioGroup>

                    <com.offline.expense.CategoryChartView
                        android:id="@+id/categoryChartView"
                        android:layout_width="match_parent"
                        android:layout_height="230dp"
                        android:layout_marginTop="10dp" />

                    <TextView
                        android:id="@+id/chartSummaryText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/muted"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Recent entries header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/recentEntriesTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Recent entries"
                        android:textColor="@color/ink"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/viewAllText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingTop="8dp"
                        android:paddingBottom="8dp"
                        android:paddingStart="4dp"
                        android:paddingEnd="0dp"
                        android:text="View all"
                        android:textSize="14sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/entriesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:orientation="vertical" />

                <TextView
                    android:id="@+id/emptyText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:gravity="center"
                    android:text="Start by adding your first expense."
                    android:textColor="@color/muted"
                    android:textSize="15sp" />

                <TextView
                    android:id="@+id/privacyInfoText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:background="@drawable/card_background"
                    android:padding="12dp"
                    android:text="Your data is stored locally. Use Backup on the History screen to prevent data loss if app data is cleared."
                    android:textColor="@color/muted"
                    android:textSize="13sp" />
            </LinearLayout>
        </ScrollView>

        <!-- ADS:
        <FrameLayout
            android:id="@+id/adContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="50dp" />
        -->
    </LinearLayout>

    <!-- ═══════════════════ SIDE DRAWER ═══════════════════ -->
    <ScrollView
        android:id="@+id/drawerScroll"
        android:layout_width="300dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="@color/background"
        android:scrollbars="none">

        <LinearLayout
            android:id="@+id/drawerView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Drawer title -->
            <TextView
                android:id="@+id/drawerTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Menu"
                android:textColor="@color/ink"
                android:textSize="22sp"
                android:textStyle="bold"
                android:paddingBottom="4dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="4dp" />

            <!-- Overview nav item -->
            <TextView
                android:id="@+id/drawerOverviewItem"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:text="📊  Overview"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="4dp" />

            <!-- History nav item -->
            <TextView
                android:id="@+id/drawerHistoryItem"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:text="📋  Full History"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="4dp" />

            <!-- Manage Categories nav item -->
            <TextView
                android:id="@+id/drawerManageCategoriesItem"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:gravity="center_vertical"
                android:paddingStart="4dp"
                android:text="🏷️  Manage Categories"
                android:textColor="@color/ink"
                android:textSize="15sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp" />

            <!-- Recent transactions section header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="RECENT"
                    android:textColor="@color/muted"
                    android:textSize="11sp" />

                <TextView
                    android:id="@+id/drawerViewAllText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="View all"
                    android:textSize="12sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/drawerEntriesContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="8dp" />

        </LinearLayout>
    </ScrollView>

</androidx.drawerlayout.widget.DrawerLayout>
